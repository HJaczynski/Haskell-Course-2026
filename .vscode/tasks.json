{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Haskell Solution (hw1)",
			"type": "shell",
			"command": "runghc",
			"args": [
				"homeworks/hw1/Solution.hs"
			],
			"group": "build"
